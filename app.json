{
  "expo": {
    "name": "Supernova",
    "slug": "supernova-travel",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "supernova",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a0a1a"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.supernovatravel.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Supernova needs camera access to capture travel photos and clips.",
        "NSPhotoLibraryUsageDescription": "Supernova needs photo library access to share your travel memories.",
        "NSLocationWhenInUseUsageDescription": "Supernova uses your location to tag travel posts and find nearby places."
      }
    },
    "android": {
      "package": "com.supernovatravel.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0a0a1a"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png",
      "output": "static"
    },
    "plugins": [
      "expo-router",
      "expo-web-browser",
      "expo-font",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0a0a1a",
          "image": "./assets/splash-icon.png",
          "imageWidth": 200
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Supernova needs photo library access to share your travel memories.",
          "cameraPermission": "Supernova needs camera access to capture travel photos and clips."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
