rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthed() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return request.auth.uid == uid;
    }

    // Users collection
    match /users/{uid} {
      allow read: if isAuthed();
      allow create: if isOwner(uid);
      allow update: if isOwner(uid);
      allow delete: if false; // deleteUserData Cloud Function only

      // Personalized feed — written exclusively by Cloud Functions (Admin SDK)
      match /feed/{postId} {
        allow read: if isOwner(uid);
        allow write: if false;
      }

      // Notifications
      match /notifications/{notifId} {
        allow read: if isOwner(uid);
        allow write: if false;
      }

      // Saved trips
      match /savedTrips/{tripId} {
        allow read, write: if isOwner(uid);
      }
    }

    // Posts
    match /posts/{postId} {
      allow read: if resource.data.visibility == 'public' || isAuthed();
      allow create: if isAuthed() && request.auth.uid == request.resource.data.authorUid;
      allow update, delete: if isAuthed() && request.auth.uid == resource.data.authorUid;

      match /comments/{commentId} {
        allow read: if isAuthed();
        allow create: if isAuthed() && request.auth.uid == request.resource.data.authorUid;
        allow update, delete: if isAuthed() && request.auth.uid == resource.data.authorUid;
      }
    }

    // Trips
    match /trips/{tripId} {
      function canRead() {
        return resource.data.visibility == 'public'
          || isOwner(resource.data.authorUid)
          || (resource.data.visibility == 'followers' && isAuthed())
          || request.auth.uid in resource.data.collaborators;
      }

      allow read: if canRead();
      allow create: if isAuthed() && request.auth.uid == request.resource.data.authorUid;
      allow update: if isAuthed() && (
        isOwner(resource.data.authorUid)
        || request.auth.uid in resource.data.collaborators
      );
      allow delete: if isAuthed() && isOwner(resource.data.authorUid);

      // Trip days subcollection
      match /days/{dayId} {
        function parentTrip() {
          return get(/databases/$(database)/documents/trips/$(tripId));
        }
        function canReadTrip() {
          return parentTrip().data.visibility == 'public'
            || isOwner(parentTrip().data.authorUid)
            || (parentTrip().data.visibility == 'followers' && isAuthed())
            || request.auth.uid in parentTrip().data.collaborators;
        }
        function canWriteTrip() {
          return isAuthed() && (
            isOwner(parentTrip().data.authorUid)
            || request.auth.uid in parentTrip().data.collaborators
          );
        }

        allow read: if canReadTrip();
        allow create, update, delete: if canWriteTrip();

        // Day activities subcollection
        match /activities/{activityId} {
          allow read: if canReadTrip();
          allow create, update, delete: if canWriteTrip();
        }
      }
    }

    // Follows
    match /follows/{docId} {
      allow read: if isAuthed();
      allow create: if isAuthed() && request.auth.uid == request.resource.data.followerId;
      allow delete: if isAuthed() && request.auth.uid == resource.data.followerId;
    }

    // Usage quotas — server-side only (Admin SDK)
    match /usage_quotas/{uid} {
      allow read, write: if false;
    }

    // Reports
    match /reports/{reportId} {
      allow create: if isAuthed();
      allow read, update, delete: if false;
    }

    // Boarding passes
    match /boarding_passes/{passId} {
      allow read, update, delete: if isAuthed() && isOwner(resource.data.ownerUid);
      allow create: if isAuthed() && request.auth.uid == request.resource.data.ownerUid;
    }

    // Reservations
    match /reservations/{reservationId} {
      allow read, update, delete: if isAuthed() && isOwner(resource.data.ownerUid);
      allow create: if isAuthed() && request.auth.uid == request.resource.data.ownerUid;
    }

    // Loyalty programs
    match /loyalty_programs/{programId} {
      allow read, update, delete: if isAuthed() && isOwner(resource.data.ownerUid);
      allow create: if isAuthed() && request.auth.uid == request.resource.data.ownerUid;
    }
  }
}
